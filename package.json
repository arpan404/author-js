{
  "name": "author-js",
  "version": "0.2.0",
  "description": "Unified authorization layer for frontend and backend applications with scoped policies, RBAC, ABAC, ReBAC, and audit logging.",
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/packages/postgres/src && cp packages/postgres/src/schema.sql dist/packages/postgres/src/schema.sql",
    "test": "bun test",
    "test:integration": "RUN_INTEGRATION=1 bun test tests/integration.test.ts",
    "typecheck": "tsc --noEmit",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "check": "bun run typecheck && bun test && bun run build",
    "bench": "bun run benchmarks/policy-scaling.bench.ts",
    "bench:policy": "bun run benchmarks/policy-scaling.bench.ts",
    "prepare": "husky",
    "prepack": "bun run check"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/packages/core/src/index.d.ts",
      "import": "./dist/packages/core/src/index.js"
    },
    "./postgres": {
      "types": "./dist/packages/postgres/src/index.d.ts",
      "import": "./dist/packages/postgres/src/index.js"
    },
    "./postgres/schema.sql": "./dist/packages/postgres/src/schema.sql",
    "./mongodb": {
      "types": "./dist/packages/mongodb/src/index.d.ts",
      "import": "./dist/packages/mongodb/src/index.js"
    },
    "./react": {
      "types": "./dist/packages/react/src/index.d.ts",
      "import": "./dist/packages/react/src/index.js"
    },
    "./express": {
      "types": "./dist/packages/express/src/index.d.ts",
      "import": "./dist/packages/express/src/index.js"
    },
    "./hono": {
      "types": "./dist/packages/hono/src/index.d.ts",
      "import": "./dist/packages/hono/src/index.js"
    },
    "./fastify": {
      "types": "./dist/packages/fastify/src/index.d.ts",
      "import": "./dist/packages/fastify/src/index.js"
    },
    "./elysia": {
      "types": "./dist/packages/elysia/src/index.d.ts",
      "import": "./dist/packages/elysia/src/index.js"
    },
    "./redis": {
      "types": "./dist/packages/redis/src/index.d.ts",
      "import": "./dist/packages/redis/src/index.js"
    },
    "./next": {
      "types": "./dist/packages/next/src/index.d.ts",
      "import": "./dist/packages/next/src/index.js"
    },
    "./next/server": {
      "types": "./dist/packages/next/src/server.d.ts",
      "import": "./dist/packages/next/src/server.js"
    },
    "./next/client": {
      "types": "./dist/packages/next/src/client.d.ts",
      "import": "./dist/packages/next/src/client.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "authorization",
    "rbac",
    "abac",
    "rebac",
    "typescript",
    "react",
    "elysia",
    "redis"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arpan404/author-js.git"
  },
  "bugs": {
    "url": "https://github.com/arpan404/author-js/issues"
  },
  "homepage": "https://github.com/arpan404/author-js#readme",
  "peerDependencies": {
    "pg": ">=8",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "mongodb": "7",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redis": "^6.0.1",
    "tinybench": "^6.0.2",
    "typescript": "^5"
  }
}
