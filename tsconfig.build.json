{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "types": ["bun"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "emitDeclarationOnly": false,
    "verbatimModuleSyntax": true
  },
  "include": ["index.ts", "packages/**/*.ts", "packages/**/*.tsx"],
  "exclude": ["tests", "node_modules", "dist"]
}
